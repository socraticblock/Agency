# Public site URL (SEO, canonicals)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (server writes — never expose service role to the client)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (blueprint emails)
RESEND_API_KEY=***

# Gemini (dev-only test route; disabled in production)
GEMINI_API_KEY=***

# Stripe Payment Links / price IDs (public — not secret)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=
NEXT_PUBLIC_STRIPE_PRICE_SCALE=
NEXT_PUBLIC_STRIPE_PRICE_SEO_ONLY=
NEXT_PUBLIC_STRIPE_PRICE_CHECKOUT_ONLY=
NEXT_PUBLIC_STRIPE_PRICE_AGENT_ONLY=

# ---- Digital Card Orders (D1 / Cloudflare) ----
# Cloudflare D1: database ID from the Cloudflare dashboard
# Get it at: Cloudflare Dashboard → Workers & Pages → genezisi-cards → Overview → Database ID
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token (for D1 HTTP API access)
# Create at: Cloudflare Dashboard → Profile → API Tokens → Create Custom Token
# Permissions: Account → D1 → Read
CLOUDFLARE_API_TOKEN=

# For local dev with Turso libsql: TURSO_DATABASE_URL=https://<account>:<token>@db.&lt;database&gt;.turso.io
# Or leave empty to use local file: ./local_cards.db
TURSO_DATABASE_URL=

# Admin panel — must match between server and client (same value in both)
ADMIN_PASSWORD=Jeftax12!
NEXT_PUBLIC_ADMIN_PASSWORD=Jeftax12!
